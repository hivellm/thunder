{
  "name": "@hivehub/thunder",
  "version": "0.1.1",
  "description": "HiveLLM binary RPC (wire v1, frozen) — length-prefixed MessagePack codec + multiplexed, config-driven client",
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hivellm/thunder.git",
    "directory": "typescript"
  },
  "keywords": [
    "rpc",
    "messagepack",
    "msgpack",
    "binary-protocol",
    "hivellm"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@vitest/coverage-v8": "^3.2.0",
    "eslint": "^9.30.0",
    "tsup": "^8.5.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.0",
    "yaml": "^2.8.0"
  }
}
