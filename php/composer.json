{
    "name": "hivellm/thunder",
    "description": "HiveLLM binary RPC (Thunder) — wire v1 codec, family profiles, multiplexed client",
    "license": "Apache-2.0",
    "type": "library",
    "require": {
        "php": ">=8.2",
        "rybakit/msgpack": "^0.9"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.2",
        "phpunit/phpunit": "^11.0",
        "symfony/yaml": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "HiveLLM\\Thunder\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HiveLLM\\Thunder\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
